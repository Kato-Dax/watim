struct IntrinsicDescription {
    signature: IntrinsicSignature
    construct: (.Token, .Array<InferenceHole> -> Word)
}

global INTRINSIC_DESCRIPTIONS_ARENA: Arena
global INTRINSIC_DESCRIPTIONS_INITIALIZED: bool
global INTRINSIC_SIGNATURES: Map<Resolved:Intrinsic, IntrinsicSignature>
global INTRINSIC_DESCRIPTIONS: Map<Resolved:Intrinsic, IntrinsicDescription>

fn construct-and(token: .Token, generic-arguments: .Array<InferenceHole>) -> Word {
    $token ~ $generic-arguments 0 Array:get ~ make Word:And make Intrinsic.And make Word.Intrinsic
}

fn construct-or(token: .Token, generic-arguments: .Array<InferenceHole>) -> Word {
    $token ~ $generic-arguments 0 Array:get ~ make Word:Or make Intrinsic.Or make Word.Intrinsic
}

fn construct-gt(token: .Token, generic-arguments: .Array<InferenceHole>) -> Word {
    $token ~ $generic-arguments 0 Array:get ~ make Word:Gt make Intrinsic.Gt make Word.Intrinsic
}

fn construct-lt(token: .Token, generic-arguments: .Array<InferenceHole>) -> Word {
    $token ~ $generic-arguments 0 Array:get ~ make Word:Lt make Intrinsic.Lt make Word.Intrinsic
}

fn construct-ge(token: .Token, generic-arguments: .Array<InferenceHole>) -> Word {
    $token ~ $generic-arguments 0 Array:get ~ make Word:Ge make Intrinsic.Ge make Word.Intrinsic
}

fn construct-le(token: .Token, generic-arguments: .Array<InferenceHole>) -> Word {
    $token ~ $generic-arguments 0 Array:get ~ make Word:Le make Intrinsic.Le make Word.Intrinsic
}

fn construct-eq(token: .Token, generic-arguments: .Array<InferenceHole>) -> Word {
    $token ~ $generic-arguments 0 Array:get ~ make Word:Eq make Intrinsic.Eq make Word.Intrinsic
}

fn construct-not-eq(token: .Token, generic-arguments: .Array<InferenceHole>) -> Word {
    $token ~ $generic-arguments 0 Array:get ~ make Word:NotEq make Intrinsic.NotEq make Word.Intrinsic
}

fn construct-mul(token: .Token, generic-arguments: .Array<InferenceHole>) -> Word {
    $token ~ $generic-arguments 0 Array:get ~ make Word:Mul make Intrinsic.Mul make Word.Intrinsic
}

fn construct-div(token: .Token, generic-arguments: .Array<InferenceHole>) -> Word {
    $token ~ $generic-arguments 0 Array:get ~ make Word:Div make Intrinsic.Div make Word.Intrinsic
}

fn construct-mod(token: .Token, generic-arguments: .Array<InferenceHole>) -> Word {
    $token ~ $generic-arguments 0 Array:get ~ make Word:Mod make Intrinsic.Mod make Word.Intrinsic
}

fn construct-add(token: .Token, generic-arguments: .Array<InferenceHole>) -> Word {
    $token ~ $generic-arguments 0 Array:get ~ make Word:Add make Intrinsic.Add make Word.Intrinsic
}

fn construct-sub(token: .Token, generic-arguments: .Array<InferenceHole>) -> Word {
    $token ~ $generic-arguments 0 Array:get ~ make Word:Sub make Intrinsic.Sub make Word.Intrinsic
}

fn construct-mem-copy(token: .Token, generic-arguments: .Array<InferenceHole>) -> Word {
    $token ~ make Intrinsic.MemCopy make Word.Intrinsic
}

fn construct-drop(token: .Token, generic-arguments: .Array<InferenceHole>) -> Word {
    $token ~ $generic-arguments 0 Array:get ~ make Word:Drop make Intrinsic.Drop make Word.Intrinsic
}

fn construct-uninit(token: .Token, generic-arguments: .Array<InferenceHole>) -> Word {
    $token ~ $generic-arguments 0 Array:get ~ make Word:Uninit make Intrinsic.Uninit make Word.Intrinsic
}

fn construct-flip(token: .Token, generic-arguments: .Array<InferenceHole>) -> Word {
    $token ~ $generic-arguments 0 Array:get ~ $generic-arguments 1 Array:get ~ make Word:Flip make Intrinsic.Flip make Word.Intrinsic
}

fn construct-store(token: .Token, generic-arguments: .Array<InferenceHole>) -> Word {
    $token ~ $generic-arguments 0 Array:get ~ make Word:Store make Intrinsic.Store make Word.Intrinsic
}

fn construct-shl(token: .Token, generic-arguments: .Array<InferenceHole>) -> Word {
    $token ~ $generic-arguments 0 Array:get ~ make Word:Shl make Intrinsic.Shl make Word.Intrinsic
}

fn construct-shr(token: .Token, generic-arguments: .Array<InferenceHole>) -> Word {
    $token ~ $generic-arguments 0 Array:get ~ make Word:Shr make Intrinsic.Shr make Word.Intrinsic
}

fn construct-rotl(token: .Token, generic-arguments: .Array<InferenceHole>) -> Word {
    $token ~ $generic-arguments 0 Array:get ~ make Word:Rotl make Intrinsic.Rotl make Word.Intrinsic
}

fn construct-rotr(token: .Token, generic-arguments: .Array<InferenceHole>) -> Word {
    $token ~ $generic-arguments 0 Array:get ~ make Word:Rotr make Intrinsic.Rotr make Word.Intrinsic
}

fn construct-mem-fill(token: .Token, generic-arguments: .Array<InferenceHole>) -> Word {
    $token ~ make Intrinsic.MemFill make Word.Intrinsic
}

fn construct-mem-grow(token: .Token, generic-arguments: .Array<InferenceHole>) -> Word {
    $token ~ make Intrinsic.MemGrow make Word.Intrinsic
}

fn construct-not(token: .Token, generic-arguments: .Array<InferenceHole>) -> Word {
    $token ~ $generic-arguments 0 Array:get ~ make Word:Not make Intrinsic.Not make Word.Intrinsic
}

fn construct-set-stack-size(token: .Token, generic-arguments: .Array<InferenceHole>) -> Word {
    $token ~ make Intrinsic.SetStackSize make Word.Intrinsic
}

fn add-sub-generic-constraints(predicate: .Array<Maybe<Type>>) -> Maybe<ByteSlice> { block (-> Maybe<ByteSlice>) {
    $predicate 0 Array:get match {
        case None -> { make Maybe.None break }
        case Some -> {}
    } @base

    $predicate 1 Array:get match {
        case None -> { make Maybe.None break }
        case Some -> {}
    } @addition

    $base match {
        case Type.Ptr -> {
            drop $addition match {
                case Type.I32 -> { make Maybe<ByteSlice>.None break }
                case _ -> { drop }
            }
            "can only add i32 to ptr" make ByteSlice make Maybe.Some break
        }
        case _ -> {}
    }
    Core:dup match {
        case Type.I8 -> {}
        case Type.I32 -> {}
        case Type.I64 -> {}
        case _ -> {
            drop
            "can only add i8, i32, i64" make ByteSlice make Maybe.Some break
        }
    }
    $addition Type:eq not if {
        "can not add two values of differing types" make ByteSlice make Maybe.Some break
    }
    make Maybe.None
} }

fn init-intrinsic-signatures() {
    $INTRINSIC_DESCRIPTIONS_INITIALIZED if {
        0 0 / drop
    }
    1 1 = #INTRINSIC_DESCRIPTIONS_INITIALIZED

    "IntrinsicSignatures" Arena:new #INTRINSIC_DESCRIPTIONS_ARENA
    &INTRINSIC_DESCRIPTIONS_ARENA @arena
    $arena \Resolved:Intrinsic-eq 26 Map:new-with-capacity #INTRINSIC_SIGNATURES
    $arena \Resolved:Intrinsic-eq 26 Map:new-with-capacity #INTRINSIC_DESCRIPTIONS

    block {
        $arena 3 Array:new-with-capacity<TypeShape> @types
        &types make Type.I8  make TypeShape.Exact Array:push-assert-no-alloc
        &types make Type.I32 make TypeShape.Exact Array:push-assert-no-alloc
        &types make Type.I64 make TypeShape.Exact Array:push-assert-no-alloc
        $types
    } @i8i32i64

    block {
        $arena 4 Array:new-with-capacity<TypeShape> @types
        &types               make TypeShape.AnyPtr Array:push-assert-no-alloc
        &types make Type.I8  make TypeShape.Exact  Array:push-assert-no-alloc
        &types make Type.I32 make TypeShape.Exact  Array:push-assert-no-alloc
        &types make Type.I64 make TypeShape.Exact  Array:push-assert-no-alloc
        $types
    } @ptri8i32i64

    block {
        $arena 4 Array:new-with-capacity<TypeShape> @types
        &types make Type.Bool make TypeShape.Exact Array:push-assert-no-alloc
        &types make Type.I8   make TypeShape.Exact Array:push-assert-no-alloc
        &types make Type.I32  make TypeShape.Exact Array:push-assert-no-alloc
        &types make Type.I64  make TypeShape.Exact Array:push-assert-no-alloc
        $types
    } @booli8i32i64

    make IntrinsicSignature {
        $arena "T" make ByteSlice Array:singleton @generic-parameters
        block {
            $arena 2 Array:new-with-capacity @parameters
            &parameters make GenericType {
                0 @index
                make Lexer:TokenTy.TOKEN_FN 0 0 Lexer:Token-new-keyword @name
            } make Type.Generic Array:push-assert-no-alloc
            &parameters make GenericType {
                0 @index
                make Lexer:TokenTy.TOKEN_FN 0 0 Lexer:Token-new-keyword @name
            } make Type.Generic Array:push-assert-no-alloc
            $parameters
        } @parameters
        $arena make GenericType {
            0 @index
            make Lexer:TokenTy.TOKEN_FN 0 0 Lexer:Token-new-keyword @name
        } make Type.Generic Array:singleton @returns

        Array:new @constraints
    } @signature-and

    &INTRINSIC_SIGNATURES make Resolved:Intrinsic.And $signature-and Map:insert-assert-no-alloc assert-none
    &INTRINSIC_DESCRIPTIONS make Resolved:Intrinsic.And $signature-and \construct-and make IntrinsicDescription Map:insert-assert-no-alloc assert-none

    &INTRINSIC_SIGNATURES make Resolved:Intrinsic.Or $signature-and Map:insert-assert-no-alloc assert-none
    &INTRINSIC_DESCRIPTIONS make Resolved:Intrinsic.Or $signature-and \construct-or make IntrinsicDescription Map:insert-assert-no-alloc assert-none

    make IntrinsicSignature {
        $arena "T" make ByteSlice Array:singleton @generic-parameters
        block {
            $arena 2 Array:new-with-capacity @parameters
            &parameters make Lexer:TokenTy.TOKEN_FN 0 0 Lexer:Token-new-keyword 0 make GenericType make Type.Generic Array:push-assert-no-alloc
            &parameters make Lexer:TokenTy.TOKEN_FN 0 0 Lexer:Token-new-keyword 0 make GenericType make Type.Generic Array:push-assert-no-alloc
            $parameters
        } @parameters
        $arena make Type.Bool Array:singleton @returns

        $arena 0 $i8i32i64 make MustBeOneOf make ConstraintOnGeneric.MustBeOneOf Array:singleton @constraints
    } @signature-cmp

    &INTRINSIC_SIGNATURES make Resolved:Intrinsic.Gt $signature-cmp Map:insert-assert-no-alloc assert-none
    &INTRINSIC_DESCRIPTIONS make Resolved:Intrinsic.Gt $signature-cmp \construct-gt make IntrinsicDescription Map:insert-assert-no-alloc assert-none

    &INTRINSIC_SIGNATURES make Resolved:Intrinsic.Lt $signature-cmp Map:insert-assert-no-alloc assert-none
    &INTRINSIC_DESCRIPTIONS make Resolved:Intrinsic.Lt $signature-cmp \construct-lt make IntrinsicDescription Map:insert-assert-no-alloc assert-none

    &INTRINSIC_SIGNATURES make Resolved:Intrinsic.Ge $signature-cmp Map:insert-assert-no-alloc assert-none
    &INTRINSIC_DESCRIPTIONS make Resolved:Intrinsic.Ge $signature-cmp \construct-ge make IntrinsicDescription Map:insert-assert-no-alloc assert-none

    &INTRINSIC_SIGNATURES make Resolved:Intrinsic.Le $signature-cmp Map:insert-assert-no-alloc assert-none
    &INTRINSIC_DESCRIPTIONS make Resolved:Intrinsic.Le $signature-cmp \construct-le make IntrinsicDescription Map:insert-assert-no-alloc assert-none

    make IntrinsicSignature {
        $arena "T" make ByteSlice Array:singleton @generic-parameters
        make Lexer:TokenTy.TOKEN_FN 0 0 Lexer:Token-new-keyword 0 make GenericType make Type.Generic @T
        block {
            $arena 2 Array:new-with-capacity @parameters
            &parameters $T Array:push-assert-no-alloc
            &parameters $T Array:push-assert-no-alloc
            $parameters
        } @parameters
        $arena make Type.Bool Array:singleton @returns
        Array:new @constraints
    } @signature-eq

    make IntrinsicDescription {
        $signature-eq @signature
        \construct-eq @construct
    } @description-eq
    &INTRINSIC_SIGNATURES make Resolved:Intrinsic.Eq $signature-eq Map:insert-assert-no-alloc assert-none
    &INTRINSIC_DESCRIPTIONS make Resolved:Intrinsic.Eq $description-eq Map:insert-assert-no-alloc assert-none

    make IntrinsicDescription {
        $signature-eq @signature
        \construct-not-eq @construct
    } @description-not-eq
    &INTRINSIC_SIGNATURES make Resolved:Intrinsic.NotEq $signature-eq Map:insert-assert-no-alloc assert-none
    &INTRINSIC_DESCRIPTIONS make Resolved:Intrinsic.NotEq $description-not-eq Map:insert-assert-no-alloc assert-none

    make IntrinsicSignature {
        $arena "T" make ByteSlice Array:singleton @generic-parameters
        make Lexer:TokenTy.TOKEN_FN 0 0 Lexer:Token-new-keyword 0 make GenericType make Type.Generic @T
        block {
            $arena 2 Array:new-with-capacity @parameters
            &parameters $T Array:push-assert-no-alloc
            &parameters $T Array:push-assert-no-alloc
            $parameters
        } @parameters
        $arena $T Array:singleton @returns

        $arena 0 $i8i32i64 make MustBeOneOf make ConstraintOnGeneric.MustBeOneOf Array:singleton @constraints
    } @signature-muldivmod

    &INTRINSIC_SIGNATURES make Resolved:Intrinsic.Mul $signature-muldivmod Map:insert-assert-no-alloc assert-none
    &INTRINSIC_DESCRIPTIONS make Resolved:Intrinsic.Mul $signature-muldivmod \construct-mul make IntrinsicDescription Map:insert-assert-no-alloc assert-none

    &INTRINSIC_SIGNATURES make Resolved:Intrinsic.Div $signature-muldivmod Map:insert-assert-no-alloc assert-none
    &INTRINSIC_DESCRIPTIONS make Resolved:Intrinsic.Div $signature-muldivmod \construct-div make IntrinsicDescription Map:insert-assert-no-alloc assert-none

    &INTRINSIC_SIGNATURES make Resolved:Intrinsic.Mod $signature-muldivmod Map:insert-assert-no-alloc assert-none
    &INTRINSIC_DESCRIPTIONS make Resolved:Intrinsic.Mod $signature-muldivmod \construct-mod make IntrinsicDescription Map:insert-assert-no-alloc assert-none

    &INTRINSIC_SIGNATURES make Resolved:Intrinsic.Shl $signature-muldivmod Map:insert-assert-no-alloc assert-none
    &INTRINSIC_DESCRIPTIONS make Resolved:Intrinsic.Shl $signature-muldivmod \construct-shl make IntrinsicDescription Map:insert-assert-no-alloc assert-none

    &INTRINSIC_SIGNATURES make Resolved:Intrinsic.Shr $signature-muldivmod Map:insert-assert-no-alloc assert-none
    &INTRINSIC_DESCRIPTIONS make Resolved:Intrinsic.Shr $signature-muldivmod \construct-shr make IntrinsicDescription Map:insert-assert-no-alloc assert-none

    &INTRINSIC_SIGNATURES make Resolved:Intrinsic.Rotl $signature-muldivmod Map:insert-assert-no-alloc assert-none
    &INTRINSIC_DESCRIPTIONS make Resolved:Intrinsic.Rotl $signature-muldivmod \construct-rotl make IntrinsicDescription Map:insert-assert-no-alloc assert-none

    &INTRINSIC_SIGNATURES make Resolved:Intrinsic.Rotr $signature-muldivmod Map:insert-assert-no-alloc assert-none
    &INTRINSIC_DESCRIPTIONS make Resolved:Intrinsic.Rotr $signature-muldivmod \construct-rotr make IntrinsicDescription Map:insert-assert-no-alloc assert-none

    make IntrinsicSignature {
        block {
            $arena 2 Array:new-with-capacity @generic-parameters
            &generic-parameters "A" make ByteSlice Array:push-assert-no-alloc
            &generic-parameters "B" make ByteSlice Array:push-assert-no-alloc
            $generic-parameters
        } @generic-parameters
        make Lexer:TokenTy.TOKEN_FN 0 0 Lexer:Token-new-keyword 0 make GenericType make Type.Generic @A
        make Lexer:TokenTy.TOKEN_FN 0 0 Lexer:Token-new-keyword 1 make GenericType make Type.Generic @B
        block {
            $arena 2 Array:new-with-capacity @parameters
            &parameters $A Array:push-assert-no-alloc
            &parameters $B Array:push-assert-no-alloc
            $parameters
        } @parameters
        $arena $A Array:singleton @returns

        block {
            $arena 3 Array:new-with-capacity<ConstraintOnGeneric> @constraints
            &constraints 0 $ptri8i32i64 make MustBeOneOf make ConstraintOnGeneric.MustBeOneOf Array:push-assert-no-alloc
            &constraints 1 $i8i32i64 make MustBeOneOf make ConstraintOnGeneric.MustBeOneOf Array:push-assert-no-alloc
            &constraints "CanAdd" make ByteSlice "foo" make ByteSlice \add-sub-generic-constraints make MustSatisfyPredicate make ConstraintOnGeneric.MustSatisfyPredicate Array:push-assert-no-alloc
            $constraints
        } @constraints
    } @signature-addsub

    &INTRINSIC_SIGNATURES make Resolved:Intrinsic.Add $signature-addsub Map:insert-assert-no-alloc assert-none
    &INTRINSIC_DESCRIPTIONS make Resolved:Intrinsic.Add $signature-addsub \construct-add make IntrinsicDescription Map:insert-assert-no-alloc assert-none

    &INTRINSIC_SIGNATURES make Resolved:Intrinsic.Sub $signature-addsub Map:insert-assert-no-alloc assert-none
    &INTRINSIC_DESCRIPTIONS make Resolved:Intrinsic.Sub $signature-addsub \construct-sub make IntrinsicDescription Map:insert-assert-no-alloc assert-none

    make IntrinsicSignature {
        Array:new @generic-parameters
        block {
            $arena 3 Array:new-with-capacity @parameters
            &parameters $arena make Type.I8 Arena:push make Type.Ptr Array:push-assert-no-alloc
            &parameters $arena make Type.I8 Arena:push make Type.Ptr Array:push-assert-no-alloc
            &parameters make Type.I32 Array:push-assert-no-alloc
            $parameters
        } @parameters
        Array:new @returns
        Array:new @constraints
    } @signature-mem-copy

    &INTRINSIC_SIGNATURES make Resolved:Intrinsic.MemCopy $signature-mem-copy Map:insert-assert-no-alloc assert-none
    &INTRINSIC_DESCRIPTIONS make Resolved:Intrinsic.MemCopy $signature-mem-copy \construct-mem-copy make IntrinsicDescription Map:insert-assert-no-alloc assert-none

    make IntrinsicSignature {
        Array:new @generic-parameters
        block {
            $arena 3 Array:new-with-capacity @parameters
            &parameters $arena make Type.I8 Arena:push make Type.Ptr Array:push-assert-no-alloc
            &parameters make Type.I8 Array:push-assert-no-alloc
            &parameters make Type.I32 Array:push-assert-no-alloc
            $parameters
        } @parameters
        Array:new @returns
        Array:new @constraints
    } @signature-mem-fill

    &INTRINSIC_SIGNATURES make Resolved:Intrinsic.MemFill $signature-mem-fill Map:insert-assert-no-alloc assert-none
    &INTRINSIC_DESCRIPTIONS make Resolved:Intrinsic.MemFill $signature-mem-fill \construct-mem-fill make IntrinsicDescription Map:insert-assert-no-alloc assert-none

    make IntrinsicSignature {
        $arena "T" make ByteSlice Array:singleton @generic-parameters
        make Lexer:TokenTy.TOKEN_FN 0 0 Lexer:Token-new-keyword 0 make GenericType make Type.Generic @T
        $arena $T Array:singleton @parameters
        Array:new @returns
        Array:new @constraints
    } @signature-drop

    &INTRINSIC_SIGNATURES make Resolved:Intrinsic.Drop $signature-drop Map:insert-assert-no-alloc assert-none
    &INTRINSIC_DESCRIPTIONS make Resolved:Intrinsic.Drop $signature-drop \construct-drop make IntrinsicDescription Map:insert-assert-no-alloc assert-none

    make IntrinsicSignature {
        $arena "T" make ByteSlice Array:singleton @generic-parameters
        make Lexer:TokenTy.TOKEN_FN 0 0 Lexer:Token-new-keyword 0 make GenericType make Type.Generic @T
        Array:new @parameters
        $arena $T Array:singleton @returns
        Array:new @constraints
    } @signature-uninit

    &INTRINSIC_SIGNATURES make Resolved:Intrinsic.Uninit $signature-uninit Map:insert-assert-no-alloc assert-none
    &INTRINSIC_DESCRIPTIONS make Resolved:Intrinsic.Uninit $signature-uninit \construct-uninit make IntrinsicDescription Map:insert-assert-no-alloc assert-none

    make IntrinsicSignature {
        block {
            $arena 2 Array:new-with-capacity @generic-parameters
            &generic-parameters "A" make ByteSlice Array:push-assert-no-alloc
            &generic-parameters "B" make ByteSlice Array:push-assert-no-alloc
            $generic-parameters
        } @generic-parameters
        make Lexer:TokenTy.TOKEN_FN 0 0 Lexer:Token-new-keyword 0 make GenericType make Type.Generic @A
        make Lexer:TokenTy.TOKEN_FN 0 0 Lexer:Token-new-keyword 1 make GenericType make Type.Generic @B
        block {
            $arena 2 Array:new-with-capacity @parameters
            &parameters $A Array:push-assert-no-alloc
            &parameters $B Array:push-assert-no-alloc
            $parameters
        } @parameters
        block {
            $arena 2 Array:new-with-capacity @returns
            &returns $B Array:push-assert-no-alloc
            &returns $A Array:push-assert-no-alloc
            $returns
        } @returns
        Array:new @constraints
    } @signature-flip

    &INTRINSIC_SIGNATURES make Resolved:Intrinsic.Flip $signature-flip Map:insert-assert-no-alloc assert-none
    &INTRINSIC_DESCRIPTIONS make Resolved:Intrinsic.Flip $signature-flip \construct-flip make IntrinsicDescription Map:insert-assert-no-alloc assert-none

    make IntrinsicSignature {
        $arena "T" make ByteSlice Array:singleton @generic-parameters
        make Lexer:TokenTy.TOKEN_FN 0 0 Lexer:Token-new-keyword 0 make GenericType make Type.Generic @T
        block {
            $arena 2 Array:new-with-capacity @parameters
            &parameters $arena $T Arena:push make Type.Ptr Array:push-assert-no-alloc
            &parameters $T Array:push-assert-no-alloc
            $parameters
        } @parameters
        Array:new @returns
        Array:new @constraints
    } @signature-store

    &INTRINSIC_SIGNATURES make Resolved:Intrinsic.Store $signature-store Map:insert-assert-no-alloc assert-none
    &INTRINSIC_DESCRIPTIONS make Resolved:Intrinsic.Store $signature-store \construct-store make IntrinsicDescription Map:insert-assert-no-alloc assert-none

    make IntrinsicSignature {
        Array:new @generic-parameters
        $arena make Type.I32 Array:singleton @parameters
        $arena make Type.I32 Array:singleton @returns
        Array:new @constraints
    } @signature-mem-grow

    &INTRINSIC_SIGNATURES make Resolved:Intrinsic.MemGrow $signature-mem-grow Map:insert-assert-no-alloc assert-none
    &INTRINSIC_DESCRIPTIONS make Resolved:Intrinsic.MemGrow $signature-mem-grow \construct-mem-grow make IntrinsicDescription Map:insert-assert-no-alloc assert-none

    make IntrinsicSignature {
        $arena "T" make ByteSlice Array:singleton @generic-parameters
        make Lexer:TokenTy.TOKEN_FN 0 0 Lexer:Token-new-keyword 0 make GenericType make Type.Generic @T
        $arena $T Array:singleton @parameters
        $arena $T Array:singleton @returns
        $arena 1 $booli8i32i64 make MustBeOneOf make ConstraintOnGeneric.MustBeOneOf Array:singleton @constraints
    } @signature-not

    &INTRINSIC_SIGNATURES make Resolved:Intrinsic.Not $signature-not Map:insert-assert-no-alloc assert-none
    &INTRINSIC_DESCRIPTIONS make Resolved:Intrinsic.Not $signature-not \construct-not make IntrinsicDescription Map:insert-assert-no-alloc assert-none

    make IntrinsicSignature {
        Array:new @generic-parameters
        $arena make Type.I32 Array:singleton @parameters
        Array:new @returns
        Array:new @constraints
    } @signature-set-stack-size

    &INTRINSIC_SIGNATURES make Resolved:Intrinsic.SetStackSize $signature-set-stack-size Map:insert-assert-no-alloc assert-none
    &INTRINSIC_DESCRIPTIONS make Resolved:Intrinsic.SetStackSize $signature-set-stack-size \construct-set-stack-size make IntrinsicDescription Map:insert-assert-no-alloc assert-none
}
fn uninit-intrinsic-signatures() {
    0 $INTRINSIC_DESCRIPTIONS_INITIALIZED !i32 / drop
    0 1 = #INTRINSIC_DESCRIPTIONS_INITIALIZED
    &INTRINSIC_DESCRIPTIONS_ARENA Arena:shred
}

fn intrinsic-signatures() -> .Map<Resolved:Intrinsic, IntrinsicSignature> {
    0 $INTRINSIC_DESCRIPTIONS_INITIALIZED !i32 / drop
    &INTRINSIC_SIGNATURES
}

fn intrinsic-descriptions() -> .Map<Resolved:Intrinsic, IntrinsicDescription> {
    0 $INTRINSIC_DESCRIPTIONS_INITIALIZED !i32 / drop
    &INTRINSIC_DESCRIPTIONS
}

variant FunctionOrExtern {
    case Extern -> Resolved:Extern
    case Function -> Function
}
fn FunctionOrExtern-format(fmt: .Formatter, self: .FunctionOrExtern) {
    $fmt $self match {
        case Extern -> { Resolved:Extern-format }
        case Function -> { Function-format }
    }
}
fn FunctionOrExtern-signature(self: .FunctionOrExtern) -> .FunctionSignature {
    $self match {
        case Extern -> { .signature }
        case Function -> { .signature }
    }
}

struct Assignment {
    token: Token
    source: Maybe<Source>
    fields: Array<Word:FieldAccess>
    type: InferenceHole
    is-store: bool
}
fn Assignment-format(fmt: .Formatter, self: .Assignment) {
    $fmt "(Assignment\n" Fmt:write
    $fmt Fmt:indent
    $fmt Fmt:write-indent
    $fmt "token=" Fmt:write
    $fmt &self.token Token-format
    $fmt ",\n" Fmt:write
    $fmt Fmt:write-indent
    $fmt "source=" Fmt:write
    $fmt \Source-format &self.source Maybe:format<_>
    $fmt ",\n" Fmt:write
    $fmt Fmt:write-indent
    $fmt "fields=" Fmt:write
    $fmt \Word:FieldAccess-format &self.fields Array:format-multi-line<_>
    $fmt ",\n" Fmt:write
    $fmt Fmt:write-indent
    $fmt "type=" Fmt:write
    $fmt &self.type InferenceHole-format
    $fmt ",\n" Fmt:write
    $fmt Fmt:write-indent
    $fmt "is-store=" Fmt:write
    $fmt $self.is-store bool-format
    $fmt Fmt:dedent
    $fmt ")" Fmt:write
}

