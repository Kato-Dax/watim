  holes=(Holes
    0=None,
    1=None,
    2=None,
    3=None,
    4=None,
    5=None,
    6=None,
    7=(Some I32)),
  nodes=[
    (FromCall
      token=(IDENT + 3 10),
      function=Add,
      generic-arguments=[(InferenceHole (IDENT + 3 10) 3), (InferenceHole (IDENT + 3 10) 4)],
      arguments=[
