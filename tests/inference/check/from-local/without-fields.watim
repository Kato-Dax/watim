[== Stdin Compiler ==]
fn without-fields(f: i32) -> i32 {
    $f
}
[== Args Compiler ==]
infer
-
without-fields
--quiet
[== Status Compiler ==]
0
[== Stdout Compiler ==]
[
  (Function
    name=(User (IDENT without-fields 1 4)),
    export=None,
    signature=(Signature
      generic-parameters=[],
      parameters=[
        (Parameter (User (IDENT f 1 19)) 0 I32)],
      returns=[I32]),
    locals=(Map
      (LocalId "f" 0 0)=(Local (User (IDENT f 1 19)) I32 (Some 0))),
    body=(Scope 0 [
      (GetLocal (IDENT f 2 6) (LocalId "f" 0 0) I32 I32 [])]))]
