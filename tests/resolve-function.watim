[== Stdin Compiler ==]
fn flip<A, B>(a: A, b: B) -> B, A {
    $b $a
}
[== Args Compiler ==]
resolve
-
--quiet
[== Status Compiler ==]
0
[== Stdout Compiler ==]
(Map
  "-"=(Module
    imports=(Map),
    type-definitions=(Map),
    globals=(Map),
    functions=(Map
      "flip"=(Function
        name=(IDENT flip 1 4),
        export=None,
        signature=(Signature
          generic-parameters=[(IDENT A 1 9), (IDENT B 1 12)],
          parameters=[
            (Parameter (User (IDENT a 1 15)) 0 (GenericType (IDENT A 1 18) 0)),
            (Parameter (User (IDENT b 1 21)) 1 (GenericType (IDENT B 1 24) 1))],
          returns=[(GenericType (IDENT B 1 30) 1), (GenericType (IDENT A 1 33) 0)]),
        locals=(Map
          (LocalId "a" 0 0)=(Local (User (IDENT a 1 15)) (Some (Parameter (User (IDENT a 1 15)) 0 (GenericType (IDENT A 1 18) 0)))),
          (LocalId "b" 0 0)=(Local (User (IDENT b 1 21)) (Some (Parameter (User (IDENT b 1 21)) 1 (GenericType (IDENT B 1 24) 1))))),
        closure-count=0,
        body=(Scope 0 [
          (GetLocal (IDENT b 2 6) (LocalId "b" 0 0) []),
          (GetLocal (IDENT a 2 9) (LocalId "a" 0 0) [])]))),
    static-data=""))
