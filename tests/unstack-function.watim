          type=(InferenceHole (IDENT b 3 13) 1),
          fields=[],
          result-type=(InferenceHole (IDENT b 4 6) 5),
          by-reference=True)]),
    (FromCall
      token=(IDENT drop 5 8),
      function=Drop,
      generic-arguments=[(InferenceHole (IDENT drop 5 8) 9)],
      arguments=[
        (FromGlobal
          token=(IDENT A 5 6),
          var=(GlobalId (IDENT A 5 6) 0 0),
