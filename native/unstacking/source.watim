    $fmt Fmt:write-indent
    $fmt "type=" Fmt:write
    $fmt &self.type InferenceHole-format
    $fmt Fmt:dedent
    $fmt ")" Fmt:write
}

variant SignatureHandle {
    case Function -> Resolved:FunctionHandle
    case Intrinsic -> Resolved:Intrinsic
}
fn SignatureHandle-format(fmt: .Formatter, self: .SignatureHandle) {
    $fmt $self match {
        case Function -> { Resolved:FunctionHandle-format }
        case Intrinsic -> { Resolved:Intrinsic-format }
    }
}

