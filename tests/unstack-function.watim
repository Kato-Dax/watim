[== Stdin Compiler ==]
global A: i32
fn main(a: i32) -> i32 {
    $a 1 + @b
    &b drop
    &A drop
    $b 0 = if {
        1
    } else {
        2
    }
}
[== Args Compiler ==]
unstack
-
main
--quiet
[== Status Compiler ==]
0
[== Stdout Compiler ==]
