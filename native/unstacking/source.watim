}
fn FromNode-format(fmt: .Formatter, self: .FromNode) {
    $fmt "(FromNode " Fmt:write
    $fmt &self.token Token-format
    $fmt " " Fmt:write
    $fmt $self.index i32-format
    $fmt " " Fmt:write
    $fmt $self.ret i32-format
    $fmt ")" Fmt:write
}

